# NOTE: These variables are PLACEHOLDERS — they are not yet wired into the
# runtime. The current code uses hardcoded values:
#   - poltergeist/scraper_swarm.py and somnus/evolution_loop.py hardcode
#     the data paths to D:\Project Wraith\data\{raw,processed}.
#   - The local LLM backend URL/model are not yet read from env at all.
# This file documents the intended configuration surface so the runtime
# can be migrated to read from env. Until that migration lands, editing
# these values has no effect.

# Local LLM backend (Ollama or llama.cpp running on localhost)
LLM_BACKEND_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b-instruct

# Data directories used by Poltergeist (raw scraped data) and Somnus (processed dataset)
WRAITH_DATA_RAW=./data/raw
WRAITH_DATA_PROCESSED=./data/processed

# Headless browser swarm size for Poltergeist
POLTERGEIST_INSTANCES=3
